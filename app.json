{
  "expo": {
    "name": "GYOCC",
    "slug": "gyocc-mobile",
    "scheme": "gyocc",
    "owner": "falcon-media-australia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/gyocc-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/gyocc-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.gyocc.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/gyocc-logo.png",
        "backgroundColor": "#0F172A"
      },
      "predictiveBackGestureEnabled": false,
      "package": "org.gyocc.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GYOCC to access your photos to upload images.",
          "cameraPermission": "Allow GYOCC to access your camera."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0bb97f0f-a1a5-4822-bf10-543d5c87542c"
      }
    }
  }
}
